<div class="auth-container">
  <h2 style="color: #457b9d; margin-bottom: 30px;">ログイン</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), data: { turbo: false }) do |f| %>
    <%= f.email_field :email, autofocus: true, placeholder: "メールアドレス", class: "auth-input" %>
    <%= f.password_field :password, placeholder: "パスワード", class: "auth-input" %>

    <% if devise_mapping.rememberable? %>
      <div style="text-align: left; margin-bottom: 20px; font-size: 0.8rem; color: #666;">
        <%= f.check_box :remember_me %> ログイン状態を保持する
      </div>
    <% end %>

    <%= f.submit "ログイン", class: "auth-btn" %>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
