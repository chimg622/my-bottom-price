<div class="auth-container">
  <h2 style="color: #457b9d; margin-bottom: 30px;">アカウント作成</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), data: { turbo: false }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= f.text_field :name, autofocus: true, placeholder: "名前", class: "auth-input" %>
    <%= f.email_field :email, placeholder: "メールアドレス", class: "auth-input" %>
    <%= f.password_field :password, placeholder: "パスワード（6文字以上）", class: "auth-input" %>
    <%= f.password_field :password_confirmation, placeholder: "パスワード再入力", class: "auth-input" %>

    <%= f.submit "登録する", class: "auth-btn" %>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
