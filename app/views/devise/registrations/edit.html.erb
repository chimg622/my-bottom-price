<%= render "shared/header" %>
<div class="auth-container">
  <h2 class="registration-main">アカウント編集</h2>

  <%= form_with model: @user, url: registration_path(resource_name), method: :put, data: { turbo: false } do |f| %>
    <%= render 'shared/error_messages', model: f.object %>

    <%= f.text_field :name, placeholder: "名前", autofocus: true, autocomplete: "name", class: "auth-input" %>
    <%= f.email_field :email, placeholder: "メールアドレス", autofocus: true, autocomplete: "email", class: "auth-input" %>
    <%= f.password_field :password, placeholder: "新しいパスワード（6文字以上）", autocomplete: "new-password", class: "auth-input" %>
    <%= f.password_field :password_confirmation, placeholder: "新しいパスワード再入力", autocomplete: "new-password", class: "auth-input" %>
    <%= f.password_field :current_password, placeholder: "現在のパスワード", autocomplete: "current-password", class: "auth-input" %>

    <%= f.submit "アカウント更新", class: "auth-btn" %>
  <% end %>

  <div>
    <%= button_to "アカウント削除", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "auth-btn" %>
  </div>
</div>
<%= render "shared/footer" %>
