<%= render "shared/header" %>
<div class="shop-container">
  <h2 class="shop-new-title">新しい店舗を登録</h2>

  <%= form_with model: @shop, local: true do |f| %>
    <div class="shop-new-box">
      <%= f.label :name, "店舗名", class: "shop-new-label" %>
      <%= f.text_field :name, placeholder: "例：Aスーパー 〇〇店", class: "shop-new-input" %>
    </div>

    <div class="shop-new-box">
      <%= f.label :address, "住所（任意）", class: "shop-new-label" %>
      <%= f.text_field :address, placeholder: "例：〇〇区△△町 1-2-3", class: "shop-new-input" %>
    </div>

    <%= f.submit "店舗を保存する", class: "shop-new-button" %>
  <% end %>

  <%= link_to "戻る", shops_path, class: "back-to-top" %>
</div>
<%= render "shared/footer" %>
