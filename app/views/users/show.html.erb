<%= render "shared/header" %>
<div class="user-container">
  <h2 class="user-title">マイページ</h2>

  <% # ユーザー基本情報カード %>
  <div class="user-card">
    <div class="user-card-icon">👤</div>
    <div class="user-card-name"><%= @user.name %></div>
    <div class="user-card-email"><%= @user.email %></div>
    <%= link_to "プロフィールを編集", edit_user_registration_path, class: "user-card-edit" %>
  </div>

  <% # 統計データ %>
  <div class="user-stats">
    <div class="user-stats-box">
      <div class="user-stats-title">店舗</div>
      <div class="user-stats-count"><%= @shops_count %></div>
    </div>
    <div class="user-stats-box">
      <div class="user-stats-title">商品</div>
      <div class="user-stats-count"><%= @items_count %></div>
    </div>
    <div class="user-stats-box">
      <div class="user-stats-title">記録</div>
      <div class="user-stats-count"><%= @prices_count %></div>
    </div>
  </div>

  <%= button_to "ログアウト", destroy_user_session_path, method: :delete, data: { turbo: false }, class: "user-logout" %>
</div>
<%= render "shared/footer" %>
