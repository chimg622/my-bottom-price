<div style="padding: 20px; background-color: #f9fbfd; min-height: 100vh;">
  <h2 style="color: #457b9d; font-size: 1.1rem; margin-bottom: 20px;">価格を記録する</h2>

  <%= form_with model: @price, local: true do |f| %>
    
    <%# 商品選択 %>
    <div style="margin-bottom: 15px;">
      <%= f.label :item_id, "商品名", style: "font-size: 0.8rem; color: #666;" %>
      <%= f.collection_select :item_id, @items, :id, :name, { prompt: "選択してください" }, { style: "width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #a8dadc;" } %>
    </div>

    <%# 店舗選択 %>
    <div style="margin-bottom: 15px;">
      <%= f.label :shop_id, "購入店舗", style: "font-size: 0.8rem; color: #666;" %>
      <%= f.collection_select :shop_id, @shops, :id, :name, { prompt: "選択してください" }, { style: "width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #a8dadc;" } %>
    </div>

    <%# 1. コントローラーの範囲を指定 (data-controller) %>
    <div data-controller="price-calculator">
      
      <%= form_with model: @price, local: true do |f| %>
        
        <%# 2. 入力項目にターゲットとアクションを設定 (data-price-calculator-target / data-action) %>
        <div style="display: flex; gap: 10px;">
          <div>
            <%= f.label :price, "価格" %>
            <%= f.number_field :price, 
                data: { 
                  price_calculator_target: "price", 
                  action: "input->price-calculator#calculate" 
                }, 
                class: "auth-input" %>
          </div>
          <div>
            <%= f.label :quantity, "内容量" %>
            <%= f.number_field :quantity, 
                data: { 
                  price_calculator_target: "quantity", 
                  action: "input->price-calculator#calculate" 
                }, 
                class: "auth-input" %>
          </div>
        </div>

        <div>
          <%= f.label :unit, "単位" %>
          <%= f.select :unit, Price.units.keys.map { |k| [k, k] }, {}, 
              data: { 
                price_calculator_target: "unit", 
                action: "change->price-calculator#calculate" 
              }, 
              class: "auth-input" %>
        </div>

        <%# 3. 計算結果を表示する場所 (data-price-calculator-target) %>
        <div style="background: #f1faee; padding: 15px; border-radius: 10px; text-align: center; margin-bottom: 20px;">
          <span style="font-size: 0.8rem; color: #666;">100単位あたりの参考単価</span>
          <div style="font-size: 1.5rem; font-weight: bold; color: #457b9d;" data-price-calculator-target="result">
            ¥0
          </div>
        </div>

        <%= f.submit "保存する", class: "auth-btn" %>
      <% end %>
    </div>


    <%= f.submit "この価格で保存", style: "width: 100%; padding: 16px; background-color: #457b9d; color: white; border: none; border-radius: 30px; font-weight: bold; font-size: 1rem;" %>

  <% end %>
</div>
